# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables and local secrets
.env
.env.*
!.env.example
*.pem
*.key

# Jupyter notebooks
.ipynb_checkpoints/

# Streamlit / dashboard local state
.streamlit/secrets.toml
.streamlit/config.toml

# Generated data and model artifacts
data/processed/*
data/external/*
models/
artifacts/
outputs/
reports/
*.pkl
*.pickle
*.joblib
*.h5
*.keras
*.onnx

# Keep data folders trackable when placeholders are added
!data/processed/.gitkeep
!data/external/.gitkeep

# Logs and temporary files
*.log
logs/
tmp/
temp/

# Build and packaging outputs
build/
dist/
*.egg-info/

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
